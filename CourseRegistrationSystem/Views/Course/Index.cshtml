@model IEnumerable<CourseRegistrationSystem.Models.Course>

<h2>Courses</h2>

<p>
    <a class="btn btn-primary" href="/Course/Create">Add New Course</a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>Course Name</th>
            <th>Description</th>
            <th>Credits</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.CourseName</td>
                <td>@item.Description</td>
                <td>@item.Credits</td>
                <td>
                    <a href="/Course/Edit/@item.Id">Edit</a> |
                    <a href="/Course/Delete/@item.Id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
